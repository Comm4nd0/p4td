# Environment variables for p4td
# Copy to .env and fill in your values

# Domain (used by Caddy for automatic HTTPS)
DOMAIN_NAME=9hj3.your-vhost.de

# Security (required in production)
DJANGO_SECRET_KEY=your-super-secret-key-here-make-it-long-and-random
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=9hj3.your-vhost.de,paws4thoughtdogs.com,www.paws4thoughtdogs.com,localhost,127.0.0.1

# Database (PostgreSQL - runs locally in Docker)
# RDS_HOSTNAME is set automatically by docker-compose.prod.yml to 'db'
RDS_DB_NAME=p4td
RDS_USERNAME=postgres
RDS_PASSWORD=your-secure-database-password
RDS_PORT=5432

# CORS (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=https://9hj3.your-vhost.de,https://paws4thoughtdogs.com,https://www.paws4thoughtdogs.com

# CSRF trusted origins (required for form submissions from the website)
CSRF_TRUSTED_ORIGINS=https://9hj3.your-vhost.de,https://paws4thoughtdogs.com,https://www.paws4thoughtdogs.com

# Email (for password reset emails)
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@paws4thoughtdogs.co.uk

# reCAPTCHA v3 (contact form)
# Generate at https://www.google.com/recaptcha/admin (choose reCAPTCHA v3)
RECAPTCHA_PUBLIC_KEY=your-recaptcha-site-key
RECAPTCHA_PRIVATE_KEY=your-recaptcha-secret-key
# Minimum score (0.0-1.0) required to pass — 0.5 is Google's default
RECAPTCHA_REQUIRED_SCORE=0.5

# Postcode -> address lookup (optional; powers the "look up postcode" button on
# a dog's Registered Vet field). Leave blank to disable — the field still works
# as a plain text box. Default provider is getAddress.io: sign up at
# https://getaddress.io, create an API key, and paste it here.
POSTCODE_LOOKUP_API_KEY=
POSTCODE_LOOKUP_PROVIDER=getaddress

# Xero accounting integration (optional; powers monthly customer invoicing —
# invoices push to Xero, owners pay via the Xero online-invoice link, payment
# status syncs back). Leave the client credentials blank to disable: invoicing
# still works locally, just without the online payment link.
# Setup: create a "Web app" at https://developer.xero.com/app/manage with the
# OAuth 2.0 redirect URI set to EXACTLY the value of XERO_REDIRECT_URI below,
# paste the client id/secret here, deploy, then as a superuser call
# POST /api/xero/connect/ and open the returned URL to authorise once.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://paws4thoughtdogs.com/api/xero/callback/
# Xero account code (e.g. your bank account's code in the Xero chart of
# accounts) that staff-recorded manual payments are booked against in Xero.
# Leave blank to keep manual payments app-only (risks the two ledgers drifting).
XERO_PAYMENT_ACCOUNT_CODE=
