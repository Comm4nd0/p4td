# Fastlane lanes for store screenshots.
#
# Pipeline:
#   1. ../tool/screenshots.sh         # capture raw PNGs into the layout below
#   2. fastlane upload_ios            # push the shots to App Store Connect
#   3. fastlane upload_android        # push the shots to Play Console
#
# Screenshots are uploaded plain (no device frames / no burned-in captions):
# frameit has no bezels for the captured emulator/simulator resolutions, so
# framing was removed. captions.strings is kept only as suggested store-listing
# copy you can paste into App Store Connect / Play Console by hand.
#
# Credentials (never commit these):
#   iOS:     App Store Connect API key — set via the env vars below.
#   Android: Play service-account JSON — path in SUPPLY_JSON_KEY.

IOS_BUNDLE_ID     = "uk.co.paws4thoughtdogs.paws4thoughtdogs"
ANDROID_PACKAGE   = "uk.co.paws4thoughtdogs.app"
LOCALE            = "en-GB"

default_platform(:ios)

platform :ios do
  lane :upload_ios do
    # Requires an App Store Connect API key. Provide it via env:
    #   ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_PATH (path to the .p8)
    api_key = app_store_connect_api_key(
      key_id:      ENV.fetch("ASC_KEY_ID"),
      issuer_id:   ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
    )
    deliver(
      api_key:               api_key,
      app_identifier:        IOS_BUNDLE_ID,
      screenshots_path:      File.expand_path("screenshots", __dir__),
      skip_binary_upload:    true,
      skip_metadata:         true,
      skip_app_version_update: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force:                 true, # no interactive HTML preview
    )
  end
end

platform :android do
  lane :upload_android do
    supply(
      package_name:           ANDROID_PACKAGE,
      json_key:               ENV.fetch("SUPPLY_JSON_KEY"), # Play service account
      metadata_path:          File.expand_path("metadata/android", __dir__),
      track:                  "alpha",
      skip_upload_apk:        true,
      skip_upload_aab:        true,
      skip_upload_metadata:   true,
      skip_upload_changelogs: true,
      skip_upload_images:     true,   # feature graphic / icon — not screenshots
      skip_upload_screenshots: false,
      validate_only:          false,
    )
  end
end
