# AWS configuration for migration script (migrate-from-aws.sh)
# Copy to aws-config.env and fill in your values

# RDS PostgreSQL
RDS_HOSTNAME=your-rds-endpoint.eu-west-1.rds.amazonaws.com
RDS_DB_NAME=p4td
RDS_USERNAME=postgres
RDS_PASSWORD=your-rds-password
RDS_PORT=5432

# S3 bucket name (media files)
AWS_STORAGE_BUCKET_NAME=p4td-media-your-account-id
